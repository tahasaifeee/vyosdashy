# Force LF line endings for shell scripts regardless of platform
*.sh        text eol=lf

# Text files — normalise to LF in the repo
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env*      text eol=lf
Dockerfile  text eol=lf

# Binary files — no line-ending conversion
*.ico       binary
*.png       binary
*.jpg       binary
*.svg       binary
